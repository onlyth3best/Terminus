[node name="aboutlabel" type="Label" parent="Panel/MarginContainer/HBoxContainer/about"]
custom_minimum_size = Vector2(180, 0)
layout_mode = 2
theme_override_fonts/font = ExtResource("3_iflcl")
theme_override_font_sizes/font_size = 35
text = "ABOUT"
horizontal_alignment = 1
vertical_alignment = 1

[node name="ScrollContainer" type="ScrollContainer" parent="Panel/MarginContainer/HBoxContainer/about"]
