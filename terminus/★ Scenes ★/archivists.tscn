layout_mode = 2

[node name="aboutcontent" type="RichTextLabel" parent="Panel/MarginContainer/HBoxContainer/about/ScrollContainer"]
custom_minimum_size = Vector2(170, 205)
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_fonts/normal_font = ExtResource("3_iflcl")
theme_override_fonts/bold_font = ExtResource("3_iflcl")
theme_override_font_sizes/normal_font_size = 23
text = "The ARCHIVISTS is a cohort of rather eccentric mmemory bargainers. We aren't supposed to tell you their names, how many there are, or any sort of information really-- though we can tell you that we're unimaginably glad you're here!

How does this work, you ask?
Well, let us explain! You tell the ARCHIVISTS of something you would like to forget… failed birthday parties, ignorant families, fake friends… and we'll make sure all information of that encounter is completelyy purged off the Internet!
That's right, just for the small price of a few bytes of data, we'll solve all your problems. Isn't that amazing?

Well, what's the bargaining?
You see, the price of our services relies largelly on how important this memory is, and how heavy its digital footprint is. Since there is more than one ARCHIVIST, all of them shall offer different prices for the service, sometimes with a little tweaks and changes depending on the specific situation.

AAny questions? Just let us know!"
autowrap_mode = 2

